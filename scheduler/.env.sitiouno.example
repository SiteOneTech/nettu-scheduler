# SitioUno Nettu Scheduler deployment
# Copy to .env and replace secrets locally or inject from Infisical/runtime.
POSTGRES_USER=nettu
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=nettuscheduler
ACCOUNT_API_KEY=replace-me
ACCOUNT_ID=sitiouno-default
PORT=5000
HOST_BIND=127.0.0.1
HOST_PORT=5055
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=55432
RUST_LOG=info
MIGRATE_ON_START=false
