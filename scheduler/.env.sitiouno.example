# Nettu Scheduler running as Calendar module on Zeus Agent Core DB.
# Canonical production source: Infisical/runtime env injection. Do not commit real secrets.
AGENT_DB_ADMIN_USER=agent_admin
AGENT_DB_ADMIN_PASSWORD=replace-me
AGENT_CALENDAR_DB_NAME=nettu_calendar
AGENT_DB_HOST_PORT=55430
CALENDAR_DB_RUNTIME_USER=calendar_runtime
CALENDAR_DB_RUNTIME_PASSWORD=replace-me
ACCOUNT_API_KEY=replace-me
ACCOUNT_ID=zeus-calendar
PORT=5000
HOST_BIND=127.0.0.1
HOST_PORT=5055
RUST_LOG=info
MIGRATE_ON_START=false
